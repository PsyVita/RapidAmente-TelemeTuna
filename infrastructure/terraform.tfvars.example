# Actual values for this deployment.

aws_region  = "ap-southeast-7"
project     = "telemetuna"
environment = "prod"
admin_cidr  = "0.0.0.0/0"
root_volume_size = 10
data_volume_size = 5   

# App credentials. ALL of these (usernames, db name, email, passwords) are pushed into
# SSM Parameter Store by Terraform and read back by the EC2 boot script to build
# /opt/RapidAmente-TelemeTuna/.env — so production no longer depends on .env.example.
# Edit before running terraform apply.

# Non-secret (have defaults; override here only if you want different values)
postgres_user      = "user"
postgres_db        = "telemetry"
grafana_admin_user = "user"
pgadmin_email      = "admin@admin.com"

# Secrets (stored as SecureString in SSM) — use strong, unique values
postgres_password      = "REPLACE_with_strong_postgres_password"
grafana_admin_password = "REPLACE_with_strong_grafana_password"
pgadmin_password       = "REPLACE_with_strong_pgadmin_password"
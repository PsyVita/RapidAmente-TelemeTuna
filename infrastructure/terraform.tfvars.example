# =============================================================================
# TelemeTuna — Terraform variables
# Copy this file to `terraform.tfvars` (gitignored) and fill in real values.
# Anything you DON'T set here falls back to the defaults in variables.tf.
# Changing any value and re-running `terraform apply` updates IN PLACE —
# you never need `terraform destroy`.
# =============================================================================

# --- Core / infrastructure ---------------------------------------------------
aws_region       = "ap-southeast-7" # Asia Pacific (Bangkok)
project          = "telemetuna"
environment      = "prod"
admin_cidr       = "0.0.0.0/0" # WARNING: open to the whole internet. Use YOUR ip/32 (curl ifconfig.me).
root_volume_size = 10          # OS disk (GB)
data_volume_size = 5           # Postgres data disk (GB) — gp3 can grow later, never shrink

# --- Backups: daily standard-tier EBS snapshots + Recycle Bin ----------------
# Your snapshot control panel — change a value, run `terraform apply`.
# Snapshots cover the DATABASE volume only (the OS disk isn't tagged, so it's skipped).
# Standard tier = incremental: you pay only for changed blocks, not the whole volume.
#
# snapshot_cron — WHEN to snapshot. DLM cron is ALWAYS in UTC; Thailand is UTC+7.
#   Minimum frequency is 1 hour. Common values (Thailand time -> what to write):
#     daily   00:00 ICT  ->  "cron(0 17 ? * * *)"     (17:00 UTC)
#     daily   06:00 ICT  ->  "cron(0 23 ? * * *)"     (23:00 UTC)
#     daily   09:00 ICT  ->  "cron(0 2 ? * * *)"      (02:00 UTC)
#     weekly  Sun 00:00 ICT ->"cron(0 17 ? * SAT *)"  (Sat 17:00 UTC = Sun 00:00 ICT)
#
# standard_retain_count       — how many recent snapshots to keep (1-1000); older roll off.
# recycle_bin_retention_days  — how long a DELETED snapshot stays recoverable (1-365).
# snapshot_state              — ENABLED (normal) or DISABLED to temporarily pause NEW
#                               snapshots. Pausing keeps existing snapshots, the policy,
#                               and the Recycle Bin; flip back to ENABLED + apply to resume.
snapshot_cron              = "cron(0 17 ? * * *)" # daily, 00:00 Asia/Bangkok
standard_retain_count      = 30                   # keep ~1 month of daily snapshots
recycle_bin_retention_days = 7                    # recover deleted snapshots for 7 days
snapshot_state             = "ENABLED"            # set "DISABLED" to temporarily pause snapshots

# --- App credentials: non-secret (usernames / db / email) --------------------
# Pushed into SSM Parameter Store and written into the instance .env at boot.
postgres_user      = "user"
postgres_db        = "telemetry"
grafana_admin_user = "user"
pgadmin_email      = "admin@admin.com"

# --- App credentials: secrets (stored as SecureString in SSM) ----------------
# Use strong, unique values. Never commit your real terraform.tfvars.
postgres_password      = "REPLACE_with_strong_postgres_password"
grafana_admin_password = "REPLACE_with_strong_grafana_password"
pgadmin_password       = "REPLACE_with_strong_pgadmin_password"
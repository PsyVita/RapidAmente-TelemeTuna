# =========================
# Environment Variables
# =========================
# Never commit secrets to GitHub. The .env.example is safe to commit.
.env
*.env

# =========================
# Application Stack (Node-RED)
# =========================
# Ignore Node-RED dependencies and cache
/services/nodered/node_modules/
/services/nodered/.npm/
/services/nodered/flows_cred.json

# Ignore ALL hidden configuration files 
services/nodered/.*.json

# Ignore ALL backup files (both hidden and visible)
services/nodered/*.backup
services/nodered/.*.backup

# =========================
# AI Assistants & IDEs
# =========================
# Ignore AI context folders
.claude/

# Standard IDE ignores (VS Code, JetBrains, etc.)
.vscode/
.idea/
*.swp
*.swo

# =========================
# OS Generated Files
# =========================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =========================
# Cloud
# =========================
# Terraform
.terraform/
*.tfstate
*.tfstate.*
crash.log
terraform.tfvars
*.auto.tfvars
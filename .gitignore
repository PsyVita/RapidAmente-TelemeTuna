nodered/.sessions*
nodered/lib/
nodered/node_modules/
nodered/flows_cred.json
nodered/settings.js
nodered/package.json
nodered/package-lock.json
nodered/.flows.json.backup
nodered/.npm/

# Editor / OS junk
.vscode/
.DS_Store